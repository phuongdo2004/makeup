{
  "compilerOptions": {
    "target": "ES2020",
    "module": "NodeNext",          // Sửa từ "esnext" thành "NodeNext"
    "moduleResolution": "NodeNext",  // Sửa từ "node" thành "NodeNext"
    "lib": ["ES2020"],
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "types": ["node"],
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "outDir": "./dist",
    "rootDir": "./"                // Đảm bảo tsc quét từ thư mục gốc
  },
  "ts-node": {
    "esm": true
  },
  "include": ["**/*.ts"],
  "exclude": ["node_modules", "dist"] // Loại trừ dist để tránh build lặp lại
}