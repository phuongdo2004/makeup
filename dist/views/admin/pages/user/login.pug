include ../../mixins/alert.pug
doctype html
html(lang="vi")
  head
    meta(charset='UTF-8')
    meta(name='viewport' content='width=device-width, initial-scale=1.0')
    title Đăng nhập hệ thống | SUSANNIE Admin
    script(src='https://cdn.tailwindcss.com')
    link(rel='stylesheet' href='https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css')
    //- link(rel='stylesheet' href='/admin/css/main.css')
    style.
      @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400..900;1,400..900&family=Plus+Jakarta+Sans:wght@300;400;500;600;700&display=swap');
      body {
        font-family: 'Plus Jakarta Sans', sans-serif;
        background-color: #000;
        color: white;
        overflow: hidden;
        display: flex;
        align-items: center;
        justify-content: center;
        height: 100vh;
        margin: 0;
      }
      .serif-font { font-family: 'Playfair Display', serif; }
      .gold-glow {
        position: absolute;
        width: 400px;
        height: 400px;
        background: radial-gradient(circle, rgba(210, 180, 140, 0.15) 0%, rgba(0,0,0,0) 70%);
        border-radius: 50%;
        z-index: 0;
      }
        /* toast start */
      :root {
          --gold-primary: #d4af37;
          --dark-bg: #1a1a1a;
          --success-color: #2ecc71;
          --warning-color: #f1c40f;
          --delete-color: #e74c3c;
      }

      #toast-container {
          position: fixed;
          top: 20px;
          right: 20px;
          z-index: 9999;
          display: flex;
          flex-direction: column;
          gap: 15px;
      }

      .toast {
          width: 350px;
          background: #fff;
          padding: 15px 20px;
          border-radius: 12px;
          box-shadow: 0 10px 30px rgba(0,0,0,0.1);
          display: flex;
          align-items: center;
          position: relative;
          overflow: hidden;
          /* Trạng thái mặc định: Ẩn */
          transform: translateX(120%);
          transition: all 0.5s cubic-bezier(0.68, -0.55, 0.265, 1.35);
          opacity: 0;
      }

      .toast.active {
          transform: translateX(0);
          opacity: 1;
      }

      /* Các loại màu sắc */
      .toast-success { border-left: 5px solid var(--success-color); }
      .toast-warning { border-left: 5px solid var(--warning-color); }
      .toast-delete  { border-left: 5px solid var(--delete-color); }

      .toast-icon {
          font-size: 24px;
          margin-right: 15px;
      }
      .toast-success .toast-icon { color: var(--success-color); }
      .toast-warning .toast-icon { color: var(--warning-color); }
      .toast-delete .toast-icon  { color: var(--delete-color); }

      .toast-content {
          display: flex;
          flex-direction: column;
      }

      .toast-title {
          font-weight: 700;
          color: var(--dark-bg);
          font-size: 16px;
          text-transform: uppercase;
          letter-spacing: 1px;
      }

      .toast-message {
          color: #666;
          font-size: 14px;
          margin-top: 3px;
      }

      .toast-close {
          position: absolute;
          top: 10px;
          right: 15px;
          cursor: pointer;
          font-size: 20px;
          color: #ccc;
          transition: 0.3s;
      }

      .toast-close:hover { color: var(--dark-bg); }

      /* Thanh Progress bar chạy ngược */
      .toast-progress {
          position: absolute;
          bottom: 0;
          left: 0;
          height: 3px;
          width: 100%;
          background: #eee;
      }

      .toast-progress::before {
          content: '';
          position: absolute;
          bottom: 0;
          left: 0;
          height: 100%;
          width: 100%;
          background: inherit;
      }

      .toast-success .toast-progress { background: var(--success-color); }
      .toast-warning .toast-progress { background: var(--warning-color); }
      .toast-delete .toast-progress  { background: var(--delete-color); }

      .toast.active .toast-progress {
          animation: progress 4s linear forwards;
      }

      @keyframes progress {
          100% { width: 0%; }
      }


  body
    +alert(3000)
    .gold-glow.-top-20.-left-20
    .gold-glow.-bottom-20.-right-20
    
