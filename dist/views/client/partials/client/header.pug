            //- SỬA LỖI DÒNG 37 Ở ĐÂY: Đưa toàn bộ class vào ngoặc (class="...")
            div(class="absolute top-full right-0 mt-2 w-40 bg-white rounded-xl shadow-xl py-2 invisible opacity-0 group-hover:visible group-hover:opacity-100 transition-all duration-300 z-50 border border-neutral-100")
              a(href="/user/profile" class="flex items-center gap-3 px-4 py-2 text-xs text-neutral-600 hover:bg-neutral-50 hover:text-black transition-colors")
                i.fa-solid.fa-user-gear
                | Tài khoản
              
              .h-px.bg-neutral-100.my-1 

              a(href="/user/logout" class="flex items-center gap-3 px-4 py-2 text-xs text-red-500 hover:bg-red-50 transition-colors font-bold")
                i.fa-solid.fa-right-from-bracket
                | Đăng xuất
      a(href="/service" class="inline-block text-center bg-[#D2B48C] text-black px-7 py-2.5 rounded-full text-sm font-bold uppercase tracking-wider hover:bg-white transition-all shadow-lg shadow-[#D2B48C]/20 whitespace-nowrap")
        | Đặt lịch ngay
  script.
    const searchInput = document.querySelector('#search-input');
    const suggestBox = document.querySelector('#search-suggest');
    console.log(searchInput);
    console.log(suggestBox);

    let debounceTimer;
    if(searchInput){
      searchInput.addEventListener('input', (e) => {
      const keyword = e.target.value.trim();
        console.log(keyword);
      clearTimeout(debounceTimer);
      
      if (keyword.length < 2) {
          suggestBox.classList.add('hidden');
          return;
      }

      // Đợi 300ms sau khi ngừng gõ mới gửi request
      debounceTimer = setTimeout(() => {
          fetch(`/service/search-suggest?keyword=${keyword}`)
              .then(res => res.json())
              .then(data => {
                  if (data.services && data.services.length > 0) {
                      renderSuggest(data.services);
                      suggestBox.classList.remove('hidden');
                  } else {
                      suggestBox.classList.add('hidden');
                  }
              });
      }, 300);
    });
    }


    function renderSuggest(services) {
        const html = services.map(item => `
            <a href="/service/detail/${item.id}" class="flex items-center gap-4 p-4 hover:bg-neutral-50 transition-colors border-b border-neutral-50 last:border-none">
                <img src="${item.images}" class="w-12 h-12 rounded-lg object-cover">
                <div>
                    <div class="text-sm font-bold text-black">${item.name}</div>
                    <div class="text-xs text-[#D2B48C]">${Number(item.price).toLocaleString()} đ</div>
                </div>
            </a>
        `).join('');
        
        suggestBox.innerHTML = html;
    }

    // Đóng hộp gợi ý khi click ra ngoài
    document.addEventListener('click', (e) => {
      if(searchInput){
        if (!searchInput.contains(e.target) && !suggestBox.contains(e.target)) {
            suggestBox.classList.add('hidden');
        }
      }
        
    });