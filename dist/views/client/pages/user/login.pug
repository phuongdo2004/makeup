extends ../../layouts/defaultLog.pug
include ../../mixins/alert.pug
block main
  +alert(3000)
  section.login-banner.py-24.text-center
    h2.text-5xl.font-bold.serif-font.italic.mb-4.drop-shadow-lg(class='md:text-6xl text-[#D2B48C]') Đăng nhập
    p.text-xs.uppercase.font-medium(class='text-white/80 md:text-sm tracking-[0.4em]')
      | Trang chủ / 
      span(class='text-[#D2B48C]') Đăng nhập

  main.container.mx-auto.px-6.-mt-16.mb-20.relative.z-10
    .max-w-lg.mx-auto.bg-white.shadow-2xl.p-10.border(class='rounded-[40px] md:p-14 border-black/5')
      //- Loại bỏ space-y để tự kiểm soát khoảng cách từng phần
      form(action='/user/login' method='POST')
        .mb-5
          label.uppercase.font-black.tracking-widest.text-neutral-400.block.mb-2.ml-1(class='text-[11px]') Tài khoản Email
          input.w-full.px-6.py-4.rounded-2xl.text-sm.font-medium.border.border-neutral-100(type='email' name = 'email' placeholder='Nhập email của bạn' class='focus:border-[#D2B48C] outline-none transition-all' required)
        
        .mb-4
          label.uppercase.font-black.tracking-widest.text-neutral-400.block.mb-2.ml-1(class='text-[11px]') Mật khẩu
          input.w-full.px-6.py-4.rounded-2xl.text-sm.font-medium.border.border-neutral-100(type='password' name = 'password' placeholder='Nhập mật khẩu của bạn' class='focus:border-[#D2B48C] outline-none transition-all' required)
        //- CỤM NÚT BẤM SÁT NHAU
        button.w-full.py-5.rounded-2xl.font-black.text-sm.uppercase.shadow-xl.transition-all(type='submit' class='tracking-[0.2em] bg-black text-[#D2B48C] hover:bg-[#D2B48C] hover:text-black shadow-[#D2B48C]/10')
          | Đăng nhập

        .text-center.mt-6
          p.text-xs.font-bold.text-neutral-600
            | Bạn chưa có tài khoản? 
            a.ml-1.transition-colors(href='/user/register' class='text-[#D2B48C] hover:text-black') Đăng ký ngay