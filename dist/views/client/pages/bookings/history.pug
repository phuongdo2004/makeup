extends ../../layouts/default.pug
include ../../mixins/alert.pug

block main
  +alert(3000)
  main.flex-1.max-w-4xl.mx-auto(class="p-6 md:p-10")
    //- Header trang lịch sử
    header.mb-8.border-b.border-neutral-100.pb-6
      h2.text-3xl.font-bold.serif-font.italic Lịch sử Đặt lịch
      p.text-neutral-400.text-base Theo dõi trạng thái các lịch hẹn dịch vụ makeup và làm tóc của em.

    //- Danh sách lịch đặt
    if bookings && bookings.length > 0
      .space-y-6
        each booking in bookings
          //- Chỉ hiển thị các lịch hẹn chưa bị xóa (is_deleted === 0)
          if booking.is_deleted === 0
            .bg-white.rounded-2xl.border.border-neutral-100.shadow-sm.p-6.transition-all(class="md:p-8 hover:shadow-md")
              
              //- Khối 1: Header của Thẻ (Ngày hẹn, Giờ hẹn và Trạng thái)
              .flex.flex-wrap.justify-between.items-center.gap-4.border-b.border-neutral-50.pb-4.mb-4
                .flex.items-center.gap-3
                  .w-11.h-11.rounded-xl.flex.items-center.justify-center.font-black.text-base(class="bg-[#FFEFF2] text-[#FF2D55]")
                    i.fa-solid.fa-calendar-heart
                  div
                    p.text-base.font-bold.text-neutral-800
                      | Ngày hẹn: #{booking.booking_date ? new Date(booking.booking_date).toLocaleDateString('vi-VN') : '--/--/----'}
                    p.text-xs.text-neutral-400.uppercase.tracking-tighter(class="mt-0.5") ID Lịch: #{booking.id}
                
                //- Trạng thái Đặt lịch
                div
                  if booking.status === 'deposited'
                    span.status-pill.bg-green-100.text-green-700.font-bold.text-sm Đã cọc tiền
                  else if booking.status === 'pending'
                    span.status-pill.bg-amber-100.text-amber-700.font-bold.text-sm Đang chờ xử lý
                  else if booking.status === 'completed'
                    span.status-pill.bg-blue-100.text-blue-700.font-bold.text-sm Đã hoàn thành
                  else
                    span.status-pill.bg-neutral-100.text-neutral-600.font-bold.text-sm Đã hủy

              //- Khối 2: Chi tiết dịch vụ & Thời gian
              .grid.grid-cols-1.gap-6.mb-6(class="md:grid-cols-3")
                div
                  span.block.text-xs.font-black.text-neutral-400.uppercase.tracking-widest.mb-1 Khung giờ hẹn
                  p.text-base.font-bold.text-neutral-800.flex.items-center.gap-2
                    i.fa-regular.fa-clock(class="text-[#FF2D55]")
                    | #{booking.slot_time}
                
                div
                  span.block.text-xs.font-black.text-neutral-400.uppercase.tracking-widest.mb-1 Địa điểm làm việc
                  p.text-sm.font-medium.text-neutral-600.line-clamp-2(title=booking.address)
                    i.fa-solid.fa-location-dot.text-neutral-400.mr-1
                    | #{booking.address}
                
                div
                  span.block.text-xs.font-black.text-neutral-400.uppercase.tracking-widest.mb-1 Tên khách hàng
                  p.text-base.font-bold.text-neutral-800.flex.items-center.gap-2
                    i.fa-solid.fa-user.text-neutral-400
                    | #{Customer.fullName}

              //- Khối 3: Chi tiết tài chính
              .bg-neutral-50.rounded-xl.p-5.grid.grid-cols-3.gap-4.text-center
                div
                  span.block.font-black.text-neutral-400.uppercase.tracking-wider.mb-1(class="text-[11px]") Tổng chi phí
                  p.text-base.font-black.text-neutral-800
                    | #{Number(booking.price).toLocaleString('vi-VN')} đ
                
                div
                  span.block.font-black.text-neutral-400.uppercase.tracking-wider.mb-1(class="text-[11px]") Đã đặt cọc
                  p.text-base.font-bold.text-green-600
                    | - #{Number(booking.deposit).toLocaleString('vi-VN')} đ
                
                div
                  span.block.font-black.text-neutral-400.uppercase.tracking-wider.mb-1(class="text-[11px]") Còn lại
                  p.text-base.font-black(class="text-[#FF2D55]")
                    | #{Number(booking.remaining_balance).toLocaleString('vi-VN')} đ

              //- Khối 4: Nút tương tác nhanh
              .flex.justify-end.gap-3.mt-4.pt-4.border-t.border-neutral-50
                a.rounded-full.font-bold.text-xs.uppercase.tracking-widest.transition-all(
                  href=`/bookings/detail/${booking.id}`
                  class="px-5 py-2.5 text-neutral-600 bg-neutral-100 hover:bg-neutral-200"
                )
                  | Xem chi tiết
                
                if booking.status === 'deposited' || booking.status === 'pending'
                  a.rounded-full.font-bold.text-xs.uppercase.tracking-widest.text-white.transition-all(
                    href="https://zalo.me/your_salon_phone" 
                    target="_blank"
                    class="px-5 py-2.5 bg-[#FF2D55] hover:bg-[#ff4f70]"
                  )
                    //- ĐÃ SỬA: Đưa .mr-1.5 vào trong cặp ngoặc đơn để không lỗi biên dịch
                    i.fa-solid.fa-comment-dots(class="mr-1.5")
                    | Liên hệ Hỗ trợ
    else
      //- Trạng thái trống khi chưa có lịch đặt
      .text-center.py-16.bg-white.rounded-2xl.border.border-neutral-100.p-8
        .w-20.h-20.bg-neutral-50.text-neutral-300.rounded-full.flex.items-center.justify-center.mx-auto.mb-6
          i.fa-solid.fa-calendar-xmark.text-3xl
        h3.text-xl.font-bold.text-neutral-800.mb-2 Em chưa có lịch hẹn nào!
        p.text-neutral-400.text-sm.mb-8.max-w-sm.mx-auto Khám phá các dịch vụ cao cấp và đặt lịch ngay nhé.
        a.px-8.py-3.rounded-full.font-bold.text-sm.uppercase.tracking-widest.text-white.transition-all.shadow-lg(
          href='/service'
          class='bg-[#FF2D55] hover:bg-[#ff4f70] shadow-[#FF2D55]/10'
        )
          | Đặt lịch ngay