extends ../../layouts/default.pug

block main
  section.service-banner.py-32.text-center
    h2.text-5xl.font-bold.serif-font.italic.mb-4.drop-shadow-lg(class='md:text-6xl text-[#D2B48C]') Chi Tiết Dịch Vụ
    p.text-xs.uppercase.font-medium(class='text-white/80 md:text-sm tracking-[0.4em]')
      | Trang chủ / Dịch vụ /
      span(class='text-[#D2B48C]') #{service.name}

  main.container.mx-auto.px-6.py-12.max-w-5xl
    .info-card.p-8.shadow-sm.mb-10.-mt-20.relative.z-10(class='bg-white rounded-[40px] md:p-12')
      .flex.flex-col.items-center.gap-8.mb-12.border-b.border-neutral-100.pb-10(class='md:flex-row')
        .relative
          img.w-32.h-32.rounded-full.object-cover.border-4.shadow-lg(src= service.images class='border-[#F5F5DC]')
          .absolute.bottom-1.right-1.bg-black.w-8.h-8.flex.items-center.justify-center.rounded-full.border-2.border-white(class='text-[#D2B48C]')
            i.fa-solid.fa-check.text-xs
        .text-center(class='md:text-left')
          h2.text-4xl.font-bold.text-black.uppercase.tracking-tight.mb-2 #{service.name}
          p.text-sm.text-neutral-500.font-medium

      .grid.grid-cols-1.gap-12(class='md:grid-cols-2')
        .space-y-6
          div
            label.uppercase.font-black.tracking-widest.text-neutral-400.block.mb-2(class='text-[10px]') Địa điểm
            p.text-sm.font-bold.leading-relaxed 100 Hai Bà Trưng, Thị trấn Lim, Huyện Tiên Du, Bắc Ninh

      .mt-12
        h4.text-sm.font-black.uppercase.mb-6.flex.items-center.gap-2(class='tracking-[0.2em]')
          span.w-8(class='h-[2px] bg-[#D2B48C]')
          | Bảng giá dịch vụ
        .bg-neutral-50.p-6.rounded-2xl.flex.justify-between.items-center.border.border-neutral-100
          div
            p.font-bold.text-lg.text-black #{service.name}
            p.text-xs.text-neutral-400.uppercase.tracking-tighter.mt-1 Thời gian dự kiến: #{service.duration} phút
          .font-black.text-xl.bg-black.inline-block.px-4.py-2.rounded-xl(class='text-[#D2B48C]') 
            | #{(service.price * 1).toLocaleString()} đ

      .mt-10
        h4.text-sm.font-black.uppercase.mb-4(class='tracking-[0.2em]') Tiện ích đi kèm 
        .flex.flex-wrap.gap-3
          span.bg-neutral-100.px-4.py-2.rounded-full.text-xs.font-bold.flex.items-center
            | #{service.amenities}

      button.w-full.mt-12.py-5.bg-black.font-bold.rounded-2xl.transition-all.uppercase.text-sm.shadow-xl(onclick='openBookingModal()' class='text-[#D2B48C] hover:bg-[#D2B48C] hover:text-black tracking-[0.2em]')
        | Đặt lịch ngay

    .py-12.border-t(class='border-black/5')
      h3.text-2xl.font-bold.serif-font.italic.mb-6 Ảnh dịch vụ
      .relative.max-w-4xl.mx-auto.my-10
        .swiper.mySwiper.overflow-hidden.shadow-2xl.bg-neutral-900(class='rounded-[30px]')
          .swiper-wrapper
            - var testImages = service.allImages ? service.allImages : [];
            each imgUrl in testImages
              .swiper-slide.flex.items-center.justify-center
                .w-full.overflow-hidden.flex.items-center.justify-center(class='h-[400px] md:h-[550px]')
                  img.max-w-full.max-h-full.object-contain(
                    src=`${imgUrl}?auto=format&fit=max&w=1200&q=80` 
                    alt=service.name
                  )

          .swiper-button-next(class='!text-[#D2B48C]')
          .swiper-button-prev(class='!text-[#D2B48C]')
          .swiper-pagination

  //#- MODAL 1: ĐẶT LỊCH DỊCH VỤ
  #bookingModal.fixed.inset-0.hidden.items-center.justify-center.p-4(class='z-[100] bg-black/60 backdrop-blur-sm' onclick='closeBookingModal()')
    .bg-white.w-full.max-w-2xl.shadow-2xl.overflow-hidden.relative.border(class='rounded-[40px] border-black/10' onclick='event.stopPropagation()')
      .p-6.border-b.border-neutral-100.flex.justify-between.items-center.bg-black(class='text-[#D2B48C]')
        h3.font-bold.text-lg.serif-font.italic.uppercase.tracking-wider ĐẶT LỊCH DỊCH VỤ
        button.text-2xl(onclick='closeBookingModal()') ×
      
      .p-8.overflow-y-auto(class='max-h-[70vh] custom-scrollbar')
        //- BƯỚC 1: Chọn Nhân viên
        .mb-8
          label.uppercase.font-black.text-neutral-400.block.mb-4(class='text-[11px] tracking-[0.2em]') 1. CHỌN CHUYÊN VIÊN
          .grid.grid-cols-2.gap-4(class='sm:grid-cols-3' id='artistList')
            - var testArtists = artists ? artists : [];
            if testArtists.length > 0
              each artist in testArtists
                .artist-item.p-4.border.border-neutral-200.rounded-2xl.text-center.cursor-pointer.transition-all(
                  class='hover:border-black'
                  data-id=artist.id 
                  data-name=artist.name 
                  onclick='selectArtist(this)'
                )
                  img.w-16.h-16.rounded-full.object-cover.mx-auto.mb-2.border(src=artist.avatar ? artist.avatar : '/images/default-avatar.png')
                  p.text-xs.font-black.text-black.uppercase.tracking-tight #{artist.name}
                  p.text-neutral-400.mt-1(class='text-[10px]') #{artist.experience || 0} năm kinh nghiệm
            else
              p.text-sm.text-neutral-500.col-span-full Chuyên viên hiện không có sẵn.

        //- BƯỚC 2: Chọn Ngày
        #dateSection.mb-8.hidden.border-t.pt-8
          label.uppercase.font-black.text-neutral-400.block.mb-4(class='text-[11px] tracking-[0.2em]') 2. CHỌN NGÀY LÀM VIỆC
          #dateList.flex.gap-3.overflow-x-auto.pb-4.no-scrollbar

        //- BƯỚC 3: Chọn Khung Giờ
        #timeSection.mb-8.hidden.border-t.pt-8
          label.uppercase.font-black.text-neutral-400.block.mb-4(class='text-[11px] tracking-[0.2em]') 3. CHỌN KHUNG GIỜ CÒN TRỐNG
          #timeList.grid.grid-cols-2.gap-3(class='sm:grid-cols-3 md:grid-cols-4')

      .p-6.bg-neutral-50.border-t.border-neutral-100.flex.gap-4
        button.flex-1.py-4.bg-white.border.border-neutral-200.rounded-2xl.font-bold.text-xs.uppercase(onclick='closeBookingModal()') Hủy bỏ
        button.py-4.bg-black.rounded-2xl.font-black.text-xs.uppercase(onclick='openConfirmModal()' class='flex-[2] text-[#D2B48C]') Xác nhận đặt lịch

  //#- MODAL 2: XÁC NHẬN THÔNG TIN
  #confirmModal.fixed.inset-0.hidden.items-center.justify-center.p-4(class='z-[110] bg-black/60 backdrop-blur-sm')
    .bg-white.w-full.max-w-xl.shadow-2xl.overflow-hidden.relative.border(class='rounded-[40px] border-black/10' onclick='event.stopPropagation()')
      .p-6.border-b.border-neutral-100.flex.justify-between.items-center
        h3.font-bold.text-lg.text-black.serif-font.italic Xác nhận thông tin
        button.text-2xl(onclick='closeConfirmModal()') ×
      .p-8
        .space-y-4
          .flex.justify-between.pb-2.border-b.border-dashed
            span.text-neutral-400 Dịch vụ:
            span.font-bold.text-black #{service.name}
          .flex.justify-between.pb-2.border-b.border-dashed
            span.text-neutral-400 Chuyên viên:
            span#selectedArtistDisplay.font-bold.text-black --
          .flex.justify-between.pb-2.border-b.border-dashed
            span.text-neutral-400 Ngày:
            span#selectedDateDisplay.font-bold --/--/2026
          .flex.justify-between.pb-2.border-b.border-dashed
            span.text-neutral-400 Giờ:
            span#displayTimeConfirm.font-bold --:--
          .flex.justify-between.pb-2.border-b.border-dashed
            span.text-neutral-400 Địa điểm:
            span.font-bold Thị trấn Lim, Huyện Tiên Du, Bắc Ninh
          .flex.justify-between.pb-2.border-b.border-dashed
            span.text-neutral-400 Tổng giá dịch vụ:
            span.font-bold.text-neutral-600 #{(service.price * 1).toLocaleString()} đ
          .flex.justify-between.pb-2.border-b.border-dashed
            span.text-neutral-400 Tiền đặt cọc:
            span.font-bold.text-black 100.000 đ
          
          .flex.justify-between.pt-4
            span.text-neutral-400 Số tiền còn nợ (Trả sau):
            span.text-xl.font-black.text-red-600 #{((service.price * 1) - 100000).toLocaleString()} đ

      .p-6.bg-neutral-50.flex.gap-4
        button.flex-1.py-4.bg-white.border.rounded-2xl.font-bold(onclick='closeConfirmModal()') Quay lại
        button.py-4.bg-black.rounded-2xl.font-black(onclick='goToPaymentPage()' class='flex-[2] text-[#D2B48C]') Thanh toán
  style.
    .no-scrollbar::-webkit-scrollbar { display: none; }
    .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
    .artist-item.selected { border-color: black; background-color: #F5F5DC; }
    .date-item.selected { background-color: black; color: #D2B48C; }
    .time-item.selected { background-color: #D2B48C; color: black; border-color: #D2B48C; }

  script(src='https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js')
  link(rel='stylesheet', href='https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css')
  script.
    document.addEventListener('DOMContentLoaded', function () {
      new Swiper('.mySwiper', {
        slidesPerView: 1,
        centeredSlides: true,
        spaceBetween: 0,
        loop: true,
        speed: 800,
        autoplay: {
          delay: 3000,
          disableOnInteraction: false,
          pauseOnMouseEnter: true,
        },
        navigation: { nextEl: '.swiper-button-next', prevEl: '.swiper-button-prev' },
        pagination: { el: '.swiper-pagination', clickable: true },
      });
    });

    let bookingData = { artistId: '', artistName: '', date: '', time: '' };

    function openBookingModal() {
      const modal = document.getElementById('bookingModal');
      modal.style.display = 'flex';
      modal.classList.remove('hidden');
    }

    function closeBookingModal() {
      const modal = document.getElementById('bookingModal');
      modal.style.display = 'none';
      modal.classList.add('hidden');
    }

    function selectArtist(element) {
      document.querySelectorAll('.artist-item').forEach(el => el.classList.remove('selected'));
      element.classList.add('selected');
      
      bookingData.artistId = element.getAttribute('data-id');
      bookingData.artistName = element.getAttribute('data-name');
      
      document.getElementById('dateSection').classList.remove('hidden');
      renderDays();

      document.getElementById('timeSection').classList.add('hidden');
      bookingData.date = '';
      bookingData.time = '';
    }

    function renderDays() {
      const dateList = document.getElementById('dateList');
      dateList.innerHTML = '';
      const daysOfWeek = ['Chủ Nhật', 'Thứ 2', 'Thứ 3', 'Thứ 4', 'Thứ 5', 'Thứ 6', 'Thứ 7'];
      const today = new Date();

      for (let i = 0; i < 7; i++) {
        const nextDate = new Date(today);
        nextDate.setDate(today.getDate() + i);

        const dayName = i === 0 ? 'Hôm nay' : daysOfWeek[nextDate.getDay()];
        const dateString = `${nextDate.getDate()}/${nextDate.getMonth() + 1}`;
        const fullDateValue = `${nextDate.getFullYear()}-${String(nextDate.getMonth() + 1).padStart(2, '0')}-${String(nextDate.getDate()).padStart(2, '0')}`;

        const dayBtn = document.createElement('div');
        dayBtn.className = 'date-item flex-shrink-0 w-24 p-3 border border-neutral-200 rounded-2xl text-center cursor-pointer transition-all hover:border-black';
        dayBtn.innerHTML = `
          <p class="text-[10px] font-bold text-neutral-400 uppercase">${dayName}</p>
          <p class="text-sm font-black text-black mt-1">${dateString}</p>
        `;
        
        dayBtn.onclick = async function() {
          document.querySelectorAll('.date-item').forEach(el => el.classList.remove('selected'));
          dayBtn.classList.add('selected');
          bookingData.date = fullDateValue;
          
          document.getElementById('timeSection').classList.add('hidden');
          
          try {
            const response = await fetch(`/service/check-busy?id_artist=${bookingData.artistId}&booking_date=${bookingData.date}`);
            const result = await response.json();
            
            if (result.success) {
              document.getElementById('timeSection').classList.remove('hidden');
              const isToday = (i === 0); 
              renderTimeSlots(result.busySlots, isToday);
            } else {
              alert("Không thể tải lịch làm việc của nghệ sĩ này!");
            }
          } catch (error) {
            console.error("Lỗi kết nối:", error);
          }
        };
        dateList.appendChild(dayBtn);
      }
    }

    // 🌟 ĐÃ SỬA: Thay đổi các ca makeup cách nhau 2 tiếng
    function renderTimeSlots(busySlots = [], isToday = false) {
      const timeList = document.getElementById('timeList');
      timeList.innerHTML = '';
      bookingData.time = ''; 

      const currentHour = new Date().getHours();

      // Vòng lặp tăng 2 đơn vị (hour += 2) để tạo khoảng cách 2 tiếng
      for (let hour = 3; hour <= 21; hour += 2) {
        
        // Nếu chọn ngày hôm nay, ẩn các ca có giờ bắt đầu nhỏ hơn hoặc bằng giờ hiện tại
        if (isToday && hour <= currentHour) {
          continue;
        }

        const startTime = `${String(hour).padStart(2, '0')}:00`;
        const endTime = `${String(hour + 2).padStart(2, '0')}:00`; // Kết thúc sau 2 tiếng
        const slotDisplay = `${startTime} - ${endTime}`;

        const isBusy = busySlots.includes(slotDisplay);
        const timeBtn = document.createElement('div');
        
        if (isBusy) {
          timeBtn.className = 'time-item p-3 border border-neutral-200 bg-neutral-100 text-neutral-400 rounded-xl text-center cursor-not-allowed font-bold text-xs line-through opacity-60';
          timeBtn.innerText = `${slotDisplay} (Bận)`;
        } else {
          timeBtn.className = 'time-item p-3 border border-neutral-200 rounded-xl text-center cursor-pointer font-bold text-xs transition-all hover:border-black text-black';
          timeBtn.innerText = slotDisplay;
          
          timeBtn.onclick = function() {
            document.querySelectorAll('.time-item').forEach(el => el.classList.remove('selected'));
            timeBtn.classList.add('selected');
            bookingData.time = slotDisplay;
          };
        }
        
        timeList.appendChild(timeBtn);
      }
    }

    function openConfirmModal() {
      if (!bookingData.artistId || !bookingData.date || !bookingData.time) {
        alert('Vui lòng hoàn thành đủ 3 bước chọn: Chuyên viên, Ngày hẹn và Giờ ca làm việc nhé!');
        return;
      }
      
      document.getElementById('selectedArtistDisplay').innerText = bookingData.artistName;
      const [year, month, day] = bookingData.date.split('-');
      document.getElementById('selectedDateDisplay').innerText = `${day}/${month}/${year}`;
      document.getElementById('displayTimeConfirm').innerText = bookingData.time;

      document.getElementById('confirmModal').style.display = 'flex';
      document.getElementById('confirmModal').classList.remove('hidden');
    }

    function closeConfirmModal() {
      document.getElementById('confirmModal').style.display = 'none';
      document.getElementById('confirmModal').classList.add('hidden');
    }

    function goToPaymentPage() {
      const form = document.createElement('form');
      form.method = 'POST';
      form.action = '/payment';
      
      const depositAmount = 100000;
      const servicePrice = parseFloat("#{service.price}");
      const remainingBalance = servicePrice - depositAmount;
      const serviceAddress = "Thị trấn Lim, Huyện Tiên Du, Bắc Ninh"; 

      const data = {
        id_service: "#{service.id}", 
        id_artist: bookingData.artistId,        
        booking_date: bookingData.date,         
        slot_time: bookingData.time,            
        price: servicePrice,
        deposit: depositAmount,                 
        remaining_balance: remainingBalance,    
        address: serviceAddress
      };

      for (const key in data) {
        const input = document.createElement('input');
        input.type = 'hidden';
        input.name = key;
        input.value = data[key];
        form.appendChild(input);
      }
      
      document.body.appendChild(form);
      form.submit();
    }