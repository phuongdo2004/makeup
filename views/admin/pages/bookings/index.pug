extends ../../layouts/default.pug
include ../../mixins/alert.pug
include ../../mixins/pagination.pug

block main
  +alert(3000)
  main.flex-1.p-10
    //- ================= HEADER SECTION =================
    header.flex.justify-between.items-start.mb-10.flex-wrap.gap-6
      div
        h2.text-3xl.font-bold.serif-font.italic Quản lý lịch đặt
        p.text-neutral-400.text-sm Theo dõi và điều phối lịch hẹn của khách hàng trong ngày.
      
      //- ĐÃ THÊM TẠI ĐÂY: Thanh tìm kiếm theo tên khách hàng
      .flex.items-center.gap-3(id="search-booking-box")
        .relative.w-80
          span.absolute.inset-y-0.left-0.flex.items-center.pl-4.text-neutral-400
            i.fa-solid.fa-magnifying-glass.text-sm
          input.w-full.pl-11.pr-4.py-3.bg-white.border.border-neutral-200.rounded-full.text-sm.font-medium.transition-all(
            type="text"
            name="keyword"
            placeholder="Tìm theo tên khách hàng..."
            value=keyword
            class="focus:border-black focus:ring-1 focus:ring-black outline-none text-neutral-800 shadow-sm"
          )
        button.px-6.py-3.bg-black.text-white.rounded-full.font-bold.text-sm.uppercase.tracking-wider.transition-all(
          button-search-booking
          class="hover:bg-neutral-800 shadow-md active:scale-95"
        ) Tìm kiếm

    //- ================= TABLE SECTION =================
    .card.overflow-hidden
      .p-8.border-b.border-neutral-50.flex.justify-between.items-center
        h3.text-xl.font-bold.serif-font.italic Chi tiết lịch hẹn
      .overflow-x-auto
        table.w-full.text-left
          thead.bg-neutral-50.uppercase.font-black.text-neutral-400.tracking-widest(class='text-[10px]')
            tr
              th.px-8.py-5 Mã đơn
              th.px-8.py-5 Khách hàng
              th.px-8.py-5 Thời gian
              th.px-8.py-5 Dịch vụ
              th.px-8.py-5 Thanh toán
          tbody.divide-y.divide-neutral-50
            if bookings && bookings.length > 0
              each item in bookings
                - var bookingId = item.id || item.booking_id
                tr.transition-all.cursor-pointer(
                  class=`hover:bg-neutral-50/50 border-l-4 ${item.status == 'pending' ? 'border-yellow-400' : (item.status == 'paid' ? 'border-green-500' : 'border-blue-400')}`
                  onclick=`window.location.href='/${prefixAdmin}/bookings/detail/${bookingId}'`
                )
                  td.px-8.py-5.font-bold.text-xs(class="pointer-events-none") #SSN-#{bookingId.substring(0, 8)}
                  td.px-8.py-5
                    p.text-sm.font-bold.text-neutral-800 #{item.fullName}
                    p.text-neutral-400(class='text-[10px]') #{item.phone}
                  td.px-8.py-5
                    .flex.items-center.gap-2
                      span.w-8.h-8.rounded-lg.flex.items-center.justify-center(class='bg-[#F5F5DC] text-[#D2B48C]')
                        i.fa-regular.fa-calendar-days(class='text-[10px]')
                      div
                        p.text-xs.font-bold #{item.booking_date}
                        p.text-neutral-400.uppercase(class='text-[10px]') #{item.time_start} - #{item.time_end}
                  td.px-8.py-5
                    span.text-xs.font-semibold #{item.serviceName}
                  td.px-8.py-5
                    .flex.flex-col.gap-1
                      span(class=`status-pill w-fit ${item.statusClass}`) #{item.statusDisplay}
            else
              tr
                td.px-8.py-10.text-center.text-neutral-400(colspan="5") Không có dữ liệu lịch đặt.

      +pagination(pagination)

  //- ================= LOGIC SCRIPT SEARCH =================
  script.
    const searchBox = document.querySelector("#search-booking-box");
    if(searchBox) {
      const input = searchBox.querySelector("input[name='keyword']");
      const btnSearch = searchBox.querySelector("[button-search-booking]");
      let url = new URL(window.location.href);

      // Hàm thực thi chuyển hướng URL kèm theo tham số keyword
      const handleSearch = () => {
        const keyword = input.value.trim();
        if(keyword) {
          url.searchParams.set("keyword", keyword);
        } else {
          url.searchParams.delete("keyword");
        }
        url.searchParams.set("page", "1"); // Đổi từ khóa thì đưa về trang 1
        window.location.href = url.href;
      };

      // Sự kiện click nút tìm kiếm
      btnSearch.addEventListener("click", handleSearch);

      // Sự kiện gõ Enter trong ô Input
      input.addEventListener("keydown", (e) => {
        if(e.key === "Enter") {
          handleSearch();
        }
      });
    }