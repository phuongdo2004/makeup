extends ../../layouts/default.pug
include ../../mixins/alert.pug
include ../../mixins/pagination.pug

block main
    +alert(3000)
    main.flex-1.p-10
      header.flex.justify-between.items-center.mb-10
        div
          h2.text-3xl.font-bold.serif-font.italic Quản lý lịch đặt
          p.text-neutral-400.text-sm Theo dõi và điều phối lịch hẹn của khách hàng trong ngày.
        .flex.gap-4
          .flex.bg-white.p-1.rounded-full.border.border-neutral-100.shadow-sm
            button.px-6.py-2.bg-black.rounded-full.font-bold.uppercase.tracking-widest.transition-all(class='text-[#D2B48C] text-[10px]') Tất cả

      //- Thống kê (Phần này bạn có thể truyền biến tổng số lượng từ controller vào nếu muốn)
      //- .grid.grid-cols-1.gap-6.mb-10(class='md:grid-cols-4')
      //-   .card.p-6.border-b-2.border-yellow-400
      //-     p.text-neutral-400.uppercase.font-black.tracking-widest(class='text-[10px]') Chờ xác nhận
      //-     h3.text-2xl.font-bold.mt-1 05
      //-   .card.p-6.border-b-2.border-blue-400
      //-     p.text-neutral-400.uppercase.font-black.tracking-widest(class='text-[10px]') Sắp đến
      //-     h3.text-2xl.font-bold.mt-1 12
      //-   .card.p-6.border-b-2.border-green-500
      //-     p.text-neutral-400.uppercase.font-black.tracking-widest(class='text-[10px]') Đã hoàn thành
      //-     h3.text-2xl.font-bold.mt-1 156
      //-   .card.p-6.border-b-2.border-red-500
      //-     p.text-neutral-400.uppercase.font-black.tracking-widest(class='text-[10px]') Đã hủy
      //-     h3.text-2xl.font-bold.mt-1 02

      .card.overflow-hidden
        .p-8.border-b.border-neutral-50.flex.justify-between.items-center
          h3.text-xl.font-bold.serif-font.italic Chi tiết lịch hẹn
          .flex.gap-4
            .relative
              input.pl-10.pr-4.py-2.bg-neutral-50.border-none.rounded-full.text-xs.outline-none(type='text' placeholder='Tìm mã lịch đặt...' class='focus:ring-1 focus:ring-[#D2B48C]')
              i.fa-solid.fa-search.absolute.left-4.text-neutral-300(class='top-1/2 -translate-y-1/2 text-[10px]')
        
        .overflow-x-auto
          table.w-full.text-left
            thead.bg-neutral-50.uppercase.font-black.text-neutral-400.tracking-widest(class='text-[10px]')
              tr
                th.px-8.py-5 Mã đơn
                th.px-8.py-5 Khách hàng
                th.px-8.py-5 Thời gian
                th.px-8.py-5 Dịch vụ
                th.px-8.py-5 Thanh toán
                th.px-8.py-5.text-right Thao tác
            tbody.divide-y.divide-neutral-50
              if bookings && bookings.length > 0
                each item in bookings
                  - var bookingId = item.id || item.booking_id
                  //- Thêm cursor-pointer và sự kiện onclick vào thẻ tr
                  tr.transition-all.cursor-pointer(
                    class=`hover:bg-neutral-50/50 border-l-4 ${item.status == 'pending' ? 'border-yellow-400' : (item.status == 'paid' ? 'border-green-500' : 'border-blue-400')}`
                    onclick=`window.location.href='/${prefixAdmin}/bookings/detail/${bookingId}'`
                  )
                    td.px-8.py-5.font-bold.text-xs(class="pointer-events-none") #SSN-#{bookingId.substring(0, 8)}
                    td.px-8.py-5
                      p.text-sm.font-bold.text-neutral-800 #{item.fullName}
                      p.text-neutral-400(class='text-[10px]') #{item.phone}
                    td.px-8.py-5
                      .flex.items-center.gap-2
                        span.w-8.h-8.rounded-lg.flex.items-center.justify-center(class='bg-[#F5F5DC] text-[#D2B48C]')
                          i.fa-regular.fa-calendar-days(class='text-[10px]')
                        div
                          p.text-xs.font-bold #{item.booking_date}
                          p.text-neutral-400.uppercase(class='text-[10px]') #{item.time_start} - #{item.time_end}
                    td.px-8.py-5
                      span.text-xs.font-semibold #{item.serviceName}
                    td.px-8.py-5
                      .flex.flex-col.gap-1
                        span(class=`status-pill w-fit ${item.statusClass}`) #{item.statusDisplay}
                    
                    //- Cột thao tác cần chặn nổi bọt sự kiện (stopPropagation) để không bị nhảy sang trang chi tiết khi nhấn nút
                    td.px-8.py-5.text-right(onclick="event.stopPropagation();")
                      .flex.justify-end.gap-2
                        if item.status == 'pending'
                          button.w-8.h-8.rounded-full.bg-green-50.text-green-600.transition-all(class='hover:bg-green-500 hover:text-white' title="Xác nhận")
                            i.fa-solid.fa-check(class='text-[10px]')
                          button.w-8.h-8.rounded-full.bg-red-50.text-red-600.transition-all(class='hover:bg-red-500 hover:text-white' title="Hủy")
                            i.fa-solid.fa-xmark(class='text-[10px]')
                        else
                          button.p-2.text-neutral-400(class='hover:text-black')
                            i.fa-solid.fa-ellipsis-vertical
              else
                tr
                  td.px-8.py-10.text-center.text-neutral-400(colspan="6") Không có dữ liệu lịch đặt.

      +pagination(pagination)