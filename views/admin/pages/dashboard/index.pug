extends ../../layouts/default.pug
include ../../mixins/alert.pug
include ../../mixins/pagination.pug
block main
  +alert(3000)
  main.flex-1.p-10
    header.flex.justify-between.items-center.mb-10
      div
        h2.text-3xl.font-bold.serif-font.italic Chào buổi sáng, #{user.fullName}!
        p.text-neutral-400.text-sm Hôm nay bạn có 5 lịch đặt mới cần xác nhận.
      .flex.gap-4
        .relative
          button.w-12.h-12.rounded-full.bg-white.border.border-neutral-100.flex.items-center.justify-center.text-neutral-50.transition-all(class='hover:text-black text-neutral-500')
            i.fa-solid.fa-bell
          span.absolute.top-0.right-0.w-3.h-3.border-2.border-white.rounded-full(class='bg-[#D2B48C]')
        
        //- Nút thêm dịch vụ dẫn đến trang tạo mới
        a.px-6.py-3.bg-black.rounded-full.font-bold.text-sm.uppercase.tracking-widest.flex.items-center.gap-2(href=`/${prefixAdmin}/service/create` class='text-[#D2B48C] hover:scale-105 transition-transform')
          i.fa-solid.fa-plus
          | Thêm dịch vụ

    //- Thống kê nhanh
    .grid.grid-cols-1.gap-6.mb-10(class='md:grid-cols-4')
      .card.p-6
        .flex.justify-between.items-start.mb-4
          .w-10.h-10.rounded-xl.flex.items-center.justify-center(class='bg-[#F5F5DC] text-[#D2B48C]')
            i.fa-solid.fa-wallet.text-lg
          span.text-green-500.text-xs.font-bold +12%
        p.text-neutral-400.uppercase.font-black.tracking-widest(class='text-[11px]') Doanh thu tháng
        h3.text-2xl.font-bold.mt-1 #{stats.revenue}đ
      
      .card.p-6
        .flex.justify-between.items-start.mb-4
          .w-10.h-10.rounded-xl.bg-neutral-100.flex.items-center.justify-center.text-neutral-400
            i.fa-solid.fa-calendar.text-lg
          span.text-neutral-400.text-xs.font-bold 0%
        p.text-neutral-400.uppercase.font-black.tracking-widest(class='text-[11px]') Lịch đặt mới
        h3.text-2xl.font-bold.mt-1 #{stats.newBookings}
      
      .card.p-6
        .flex.justify-between.items-start.mb-4
          .w-10.h-10.rounded-xl.bg-neutral-100.flex.items-center.justify-center.text-neutral-400
            i.fa-solid.fa-users.text-lg
          span.text-green-500.text-xs.font-bold +5
        p.text-neutral-400.uppercase.font-black.tracking-widest(class='text-[11px]') Tổng khách hàng
        h3.text-2xl.font-bold.mt-1 #{stats.totalCustomers}
      
      .card.p-6.border-2(class='border-[#D2B48C]/30 bg-[#F5F5DC]/20')
        .flex.justify-between.items-start.mb-4
          .w-10.h-10.rounded-xl.flex.items-center.justify-center.text-white(class='bg-[#D2B48C]')
            i.fa-solid.fa-star.text-lg
          span.text-xs.font-bold(class='text-[#D2B48C]') 4.9/5
        p.text-neutral-400.uppercase.font-black.tracking-widest(class='text-[11px]') Đánh giá TB
        h3.text-2xl.font-bold.mt-1 Tuyệt vời

    .card.overflow-hidden
      .p-8.border-b.border-neutral-100.flex.justify-between.items-center
        h3.text-xl.font-bold.serif-font.italic Lịch đặt gần đây
        a.text-xs.font-bold.uppercase.tracking-widest(href='#' class='text-[#D2B48C] hover:underline') Xem tất cả
      
      .overflow-x-auto
        table.w-full.text-left
          thead.bg-neutral-50.uppercase.font-black.text-neutral-400.tracking-widest(class='text-[10px]')
            tr
              th.px-8.py-4 Khách hàng
              th.px-8.py-4 Dịch vụ
              th.px-8.py-4 Ngày hẹn
              th.px-8.py-4 Giá tiền
              th.px-8.py-4 Trạng thái
              th.px-8.py-4.text-right Thao tác
          tbody.divide-y.divide-neutral-50
            if bookings.length > 0
              each item in bookings
                tr.transition-all(class='hover:bg-neutral-50/50')
                  td.px-8.py-5
                    .flex.items-center.gap-3
                      //- Avatar lấy chữ cái đầu hoặc ảnh nếu có
                      .w-8.h-8.rounded-full.bg-neutral-200.flex.items-center.justify-center.font-bold.text-xs.uppercase #{item.fullName.charAt(0)}
                      div
                        p.text-sm.font-bold #{item.fullName}
                        p.text-neutral-400(class='text-[10px]') #{item.phone}
                  td.px-8.py-5
                    span.text-xs.font-medium #{item.serviceName}
                  td.px-8.py-5
                    p.text-xs.font-bold #{item.booking_date}
                    p.text-neutral-400(class='text-[10px]') #{item.bookingTime}
                  td.px-8.py-5
                    span.font-bold.text-sm #{item.price.toLocaleString()}đ
                  td.px-8.py-5
                    //- Sử dụng class và label đã xử lý từ Controller
                    span(class=`status-pill ${item.statusClass}`) #{item.statusDisplay}
                  td.px-8.py-5.text-right
                    button.text-neutral-400.transition-all.mx-2(class='hover:text-black')
                      i.fa-solid.fa-check
                    button.text-neutral-400.transition-all.mx-2(class='hover:text-red-500')
                      i.fa-solid.fa-xmark
            else
              tr
                td.px-8.py-10.text-center.text-neutral-400(colspan="6") Không có lịch đặt nào.

      //- GỌI MIXIN PHÂN TRANG TẠI ĐÂY
      +pagination(pagination)