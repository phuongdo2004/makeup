extends ../../layouts/default.pug
include ../../mixins/alert.pug

block main
  +alert(3000)
  main(class="flex-1 p-10 bg-neutral-50 min-h-screen")
    
    //- HEADER TRANG CHÀO USER
    header(class="flex justify-between items-center mb-8")
      div
        h2(class="text-3xl font-bold serif-font italic") Chào buổi sáng, #{user.fullName}!
        p(class="text-neutral-400 text-sm") Hệ thống tổng hợp báo cáo tài chính và hiệu suất đặt lịch.
      div(class="flex gap-4")
        a(href=`/${prefixAdmin}/service/create` class="px-6 py-3 bg-black rounded-full font-bold text-sm uppercase tracking-widest flex items-center gap-2 text-[#D2B48C] hover:scale-105 transition-transform")
          i.fa-solid.fa-plus
          | Thêm dịch vụ

    //- BỘ LỌC KHOẢNG NGÀY (DATE RANGE FILTER)
    form(action=`/${prefixAdmin}/dashboard` method="GET" class="bg-white p-5 rounded-2xl border border-neutral-200/60 shadow-sm flex flex-wrap items-end gap-5 mb-8")
      div(class="flex flex-col gap-[6px]")
        label(class="text-xs font-bold text-neutral-400 uppercase tracking-wider") Từ ngày
        input(
          type="date" 
          name="startDate" 
          value=startDate 
          class="border border-neutral-200 rounded-xl px-4 py-2.5 text-sm font-medium text-zinc-700 bg-neutral-50 focus:outline-none focus:ring-2 focus:ring-[#D2B48C] focus:bg-white transition-all"
        )
      div(class="flex flex-col gap-[6px]")
        label(class="text-xs font-bold text-neutral-400 uppercase tracking-wider") Đến ngày
        input(
          type="date" 
          name="endDate" 
          value=endDate 
          class="border border-neutral-200 rounded-xl px-4 py-2.5 text-sm font-medium text-zinc-700 bg-neutral-50 focus:outline-none focus:ring-2 focus:ring-[#D2B48C] focus:bg-white transition-all"
        )
      button(
        type="submit" 
        class="bg-[#D2B48C] text-zinc-950 font-semibold px-6 py-3 rounded-xl text-sm hover:bg-[#bfa27e] transition-colors shadow-sm cursor-pointer"
      ) 🔍 Lọc kết quả

    //- KHỐI THỐNG KÊ NHANH (3 CARDS CHẠY ĐỘNG THEO NGÀY)
    div(class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8")
      //- Card Doanh thu tổng hợp thực tế
      div(class="p-6 bg-white rounded-2xl border border-neutral-200/60 shadow-sm flex justify-between items-center")
        div
          p(class="text-neutral-400 uppercase font-black tracking-widest text-[11px]") Tổng doanh thu thực tế
          h3(class="text-2xl font-bold mt-1 text-zinc-900") #{stats.revenue}đ
        div(class="w-12 h-12 bg-amber-50 rounded-xl flex items-center justify-center text-[#D2B48C] text-xl font-bold") 💰
      
      //- Card Số lượng lịch hẹn thành công
      div(class="p-6 bg-white rounded-2xl border border-neutral-200/60 shadow-sm flex justify-between items-center")
        div
          p(class="text-neutral-400 uppercase font-black tracking-widest text-[11px]") Số lịch đặt thành công
          h3(class="text-2xl font-bold mt-1 text-zinc-900") #{stats.totalBookings} đơn
        div(class="w-12 h-12 bg-blue-50 rounded-xl flex items-center justify-center text-blue-500 text-xl font-bold") 📅
      
      //- Card Tổng khách hàng hệ thống
      div(class="p-6 bg-white rounded-2xl border border-neutral-200/60 shadow-sm flex justify-between items-center")
        div
          p(class="text-neutral-400 uppercase font-black tracking-widest text-[11px]") Tổng khách hàng đăng ký
          h3(class="text-2xl font-bold mt-1 text-zinc-900") #{stats.totalCustomers} tài khoản
        div(class="w-12 h-12 bg-purple-50 rounded-xl flex items-center justify-center text-purple-500 text-xl font-bold") 👥

    //- KHỐI BIỂU ĐỒ VÀ CHI TIẾT SỐ LIỆU ĐẶT CẠNH NHAU
    div(class="grid grid-cols-1 gap-8")
      
      //- ĐỒ THỊ XU HƯỚNG
      div(class="w-full bg-white p-6 rounded-2xl border border-neutral-200/70 shadow-sm flex flex-col")
        div(class="flex justify-between items-center mb-6")
          h4(class="font-bold text-zinc-900 text-base") Đồ thị xu hướng doanh thu tổng hợp từng ngày
          span(class="text-xs font-medium text-emerald-600 bg-emerald-50 px-[10px] py-[4px] rounded-full") Đơn vị: VNĐ
        div(class="min-h-[260px] relative")
          canvas#rangeRevenueChart

      //- BẢNG LIỆT KÊ CHI TIẾT (Mở rộng toàn bộ chiều rộng màn hình để hiển thị đủ 5 cột cực đẹp)
      div(class="w-full bg-white p-6 rounded-2xl border border-neutral-200/70 shadow-sm flex flex-col mt-4")
        h4(class="font-bold text-zinc-900 text-base mb-4") Báo cáo phân tách dòng tiền chi tiết
        div(class="overflow-x-auto w-full")
          table(class="w-full text-left text-sm min-w-[700px]")
            thead(class="bg-neutral-50 text-neutral-500 text-xs font-bold uppercase tracking-wider sticky top-0")
              tr
                th(class="p-4") Ngày
                th(class="p-4 text-center") Số đơn
                th(class="p-4 text-right text-blue-600") Tiền đặt cọc
                th(class="p-4 text-right text-amber-600") Đã thanh toán
                th(class="p-4 text-right text-emerald-600 bg-emerald-50/50 rounded-t-lg") Tổng doanh thu
            tbody(class="divide-y divide-neutral-100 text-zinc-700")
              if revenueChartData && revenueChartData.length > 0
                each item in revenueChartData
                  tr(class="hover:bg-neutral-50/50 transition-colors")
                    td(class="p-4 font-medium") #{item.booking_date}
                    td(class="p-4 text-center font-bold text-neutral-500") #{item.daily_bookings}
                    //- Cột hiển thị riêng tiền đặt cọc
                    td(class="p-4 text-right font-medium text-blue-600") #{item.daily_deposited.toLocaleString('vi-VN')} đ
                    //- Cột hiển thị riêng tiền đã thanh toán xong
                    td(class="p-4 text-right font-medium text-amber-600") #{item.daily_paid.toLocaleString('vi-VN')} đ
                    //- Cột Tổng gộp cuối cùng
                    td(class="p-4 text-right font-bold text-emerald-600 bg-emerald-50/20") #{item.daily_revenue.toLocaleString('vi-VN')} đ
              else
                tr
                  td(colspan="5" class="p-4 text-center text-neutral-400") Không có dữ liệu doanh thu trong khoảng ngày này.

  //- NHÚNG THƯ VIỆN CHART.JS QUA CDN
  script(src="https://cdn.jsdelivr.net/npm/chart.js")
  script.
    const rawData = !{JSON.stringify(revenueChartData || [])};
    
    const labels = rawData.map(item => item.booking_date);
    const dataRevenue = rawData.map(item => item.daily_revenue);

    const ctx = document.getElementById('rangeRevenueChart').getContext('2d');
    
    const gradient = ctx.createLinearGradient(0, 0, 0, 300);
    gradient.addColorStop(0, 'rgba(210, 180, 140, 0.4)');
    gradient.addColorStop(1, 'rgba(210, 180, 140, 0.0)');

    new Chart(ctx, {
      type: 'line',
      data: {
        labels: labels,
        datasets: [{
          label: 'Tổng doanh thu (VNĐ)',
          data: dataRevenue,
          borderColor: '#D2B48C',
          borderWidth: 3,
          backgroundColor: gradient,
          fill: true,
          tension: 0.35,
          pointBackgroundColor: '#D2B48C',
          pointRadius: 4,
          pointHoverRadius: 7
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
          legend: { display: false }
        },
        scales: {
          x: { grid: { display: false } },
          y: { 
            beginAtZero: true,
            grid: { color: '#f3f4f6' }
          }
        }
      }
    });